# Copy to .env (gitignored) and fill in. Loaded automatically by `npm run dev:api` / `npm start`.
GEMINI_API_KEY=your-key-from-aistudio.google.com
# GEMINI_MODEL=gemini-flash-lite-latest
# RATE_LIMIT_MAX=15
# RATE_LIMIT_WINDOW_MS=3600000
# Requests with header x-bypass-key matching this value skip rate limiting (operator use).
# On your own devices run once in the browser console: localStorage.setItem('onoma-bypass-key', '<value>')
# RATE_LIMIT_BYPASS_KEY=

